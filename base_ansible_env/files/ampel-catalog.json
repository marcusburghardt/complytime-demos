    "groups": [
      {
        "id": "bp",
        "title": "Branch Protection",
        "controls": [
          {
            "id": "bp-1",
            "title": "Require Pull Request Reviews",
            "parts": [
              {
                "id": "bp-1_stmt",
                "name": "statement",
                "prose": "Protected branches must require pull request reviews before merging."
              }
            ]
          },
          {
            "id": "bp-2",
            "title": "Require Status Checks Before Merging",
            "parts": [
              {
                "id": "bp-2_stmt",
                "name": "statement",
                "prose": "Protected branches must require status checks to pass before merging."
              }
            ]
          },
          {
            "id": "bp-3",
            "title": "Require Signed Commits",
            "parts": [
              {
                "id": "bp-3_stmt",
                "name": "statement",
                "prose": "Protected branches must require signed commits."
              }
            ]
          },
          {
            "id": "bp-4",
            "title": "Restrict Force Pushes",
            "parts": [
              {
                "id": "bp-4_stmt",
                "name": "statement",
                "prose": "Force pushes to protected branches must be restricted."
              }
            ]
          },
          {
            "id": "bp-5",
            "title": "Require Minimum Approvals",
            "parts": [
              {
                "id": "bp-5_stmt",
                "name": "statement",
                "prose": "Pull requests to protected branches must have a minimum number of approvals."
              }
            ]
          }
        ]
      }
    ]
  }
